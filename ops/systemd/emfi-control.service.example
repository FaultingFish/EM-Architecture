[Unit]
Description=EMFI Control hardware service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=lab
Group=lab
SupplementaryGroups=dialout plugdev
WorkingDirectory=/home/lab/EM-Architecture/control
Environment="PATH=/home/lab/EM-Architecture/.venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/lab/EM-Architecture/.venv/bin/uvicorn control.main:app --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/home/lab/.config/emfi-control /home/lab/.local/share/emfi-control

[Install]
WantedBy=multi-user.target
