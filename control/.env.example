# Optional overrides for Control. Place a `.env` next to pyproject.toml.

# Bind host/port
CONTROL_HOST=0.0.0.0
CONTROL_PORT=8001

# Override config path (defaults to ~/.config/emfi-control/config.json)
# CONTROL_CONFIG=/path/to/config.json

# Override storage path (defaults to ~/.local/share/emfi-control/sessions)
# CONTROL_DATA_DIR=/path/to/data

# Develop service URL (used by Control to fetch build artifacts)
DEVELOP_URL=http://localhost:8002

# External binaries (auto-detected on PATH if unset)
# OPENOCD_BIN=/usr/local/bin/openocd
# DSLITE_BIN=/opt/ti/ccs/ccs_base/DebugServer/bin/DSLite
